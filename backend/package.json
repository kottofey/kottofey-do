    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "lodash-es": "^4.18.1",
    "ms": "^2.1.3",
    "mysql2": "^3.22.3",
    "pino": "^10.3.1",
    "qs": "^6.15.1",
    "sequelize": "^6.37.8",
    "umzug": "^3.8.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/chalk": "^0.4.31",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "@types/sequelize": "^4.28.20",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "chalk": "^5.6.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "sequelize-typescript": "^2.1.6",
    "tsc-alias": "^1.8.17",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
